# Optional: create a data directory for persistent DB/contacts on AWS.
# To use it, set AUTH_DB_PATH and CONTACTS_FILE via: eb setenv AUTH_DB_PATH=/var/app/data/auth.db CONTACTS_FILE=/var/app/data/contacts.json
commands:
  01_create_data_dir:
    command: "mkdir -p /var/app/data && chown webapp:webapp /var/app/data"
    ignoreErrors: false
