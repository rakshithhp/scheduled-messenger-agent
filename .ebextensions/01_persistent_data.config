# Create a data directory outside the deployed app so DB and contacts survive redeploys.
# AUTH_DB_PATH and CONTACTS_FILE point to this dir so they are writable on AWS.
option_settings:
  aws:elasticbeanstalk:application:environment:
    AUTH_DB_PATH: /var/app/data/auth.db
    CONTACTS_FILE: /var/app/data/contacts.json
commands:
  01_create_data_dir:
    command: "mkdir -p /var/app/data && chown webapp:webapp /var/app/data"
    ignoreErrors: false
