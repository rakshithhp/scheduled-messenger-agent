# Copy to .env and fill in your values

# Auth (required in production)
SECRET_KEY=your-secret-key
JWT_SECRET=your-jwt-secret
# Optional: persistent DB path on AWS (e.g. /var/app/current/data/auth.db or an EFS path)
# AUTH_DB_PATH=/path/to/auth.db

# OpenAI API (for parsing natural language requests)
OPENAI_API_KEY=sk-...

# Message backend: twilio or sns (default: twilio)
MESSAGE_BACKEND=twilio

# Twilio (when MESSAGE_BACKEND=twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Amazon SNS (when MESSAGE_BACKEND=sns)
# Use IAM role when running on AWS; otherwise set these
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Optional: Customize the model
OPENAI_MODEL=gpt-4o-mini
