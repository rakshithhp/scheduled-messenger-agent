# Copy to .env and fill in your values

# OpenAI API (for parsing natural language requests)
OPENAI_API_KEY=sk-...

# Message backend: twilio or sns (default: twilio)
MESSAGE_BACKEND=twilio

# Twilio (when MESSAGE_BACKEND=twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Amazon SNS (when MESSAGE_BACKEND=sns)
# Use IAM role when running on AWS; otherwise set these
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Optional: Customize the model
OPENAI_MODEL=gpt-4o-mini
